---
const steps = [
  {
    n: '1',
    title: 'Add your district and sites',
    body: 'Tell EDU Mileage+ where you work. Add school sites by address, and calibrate the GPS exactly when you arrive in the parking lot for pinpoint accuracy.',
  },
  {
    n: '2',
    title: 'Drive your day',
    body: 'When your schedule says you\'re working, the app detects when you leave one site and arrive at another. Routes are recorded automatically. No buttons, no app to open.',
  },
  {
    n: '3',
    title: 'Approve and export',
    body: 'At the end of the period, build a report, review trips by day, exclude anything personal, and export to PDF or CSV. Submit to your district. Done.',
  },
];
---
<section id="how-it-works" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="text-sm font-semibold tracking-widest uppercase text-brand-700 mb-3">
        How it works
      </p>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-slate-900">
        Set it up once. Then forget about it.
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8 md:gap-6 lg:gap-10">
      {steps.map((step) => (
        <div class="relative">
          <div aria-hidden="true" class="flex items-center justify-center w-14 h-14 rounded-2xl bg-brand-700 text-white font-display font-bold text-2xl mb-5 shadow-lg shadow-brand-900/15">
            {step.n}
          </div>
          <h3 class="font-display text-xl md:text-2xl font-bold tracking-tight text-slate-900 mb-3">
            <span class="sr-only">Step {step.n}: </span>{step.title}
          </h3>
          <p class="text-slate-600 leading-relaxed">
            {step.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
