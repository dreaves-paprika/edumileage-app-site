---
const features = [
  {
    label: 'Automatic',
    title: 'Drive between schools. The app does the rest.',
    body: 'Geofencing detects when you leave one site and arrive at another, then logs the trip with a GPS-measured route — no buttons, no apps to open, no end-of-month reconstruction. Stops are recognized automatically; drive-throughs don\'t become accidental trips.',
    image: '/screenshots/01_Dashboard.png',
    bullets: [
      'Background trip detection during your work schedule',
      'GPS route capture, not straight-line estimates',
      'Drive-by protection so passing a school doesn\'t log a trip',
    ],
  },
  {
    label: 'District-aware',
    title: 'Built for how district reimbursement actually works.',
    body: 'Multiple districts, schedule-aware tracking, and district-approved distances per route. Trips outside your work hours are flagged for review. The IRS standard rate is built in, with per-district overrides if your employer reimburses differently.',
    image: '/screenshots/02_Trips.png',
    bullets: [
      'Multi-district support with separate reports per district',
      'District-approved mileage per route, not just GPS estimates',
      'Out-of-schedule trips flagged for confirmation, not silently logged',
    ],
  },
  {
    label: 'Audit-ready',
    title: 'Reports that hold up under review.',
    body: 'Build a reimbursement report for any date range, review every trip, swipe to exclude, then approve. The IRS rate is locked at approval. Export to PDF (detailed or condensed), CSV, or generate a year-end IRS Annual Report covering every district.',
    image: '/screenshots/04_Reports.png',
    bullets: [
      'PDF, CSV, and IRS Annual Report exports',
      'Locked totals once a report is approved',
      'GPS miles, approved miles, and unreimbursed miles tracked separately',
    ],
  },
];
---
<section id="features" class="py-20 md:py-28 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="text-sm font-semibold tracking-widest uppercase text-brand-700 mb-3">
        What makes it different
      </p>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-slate-900">
        Three things competitors can't match for educators.
      </h2>
    </div>

    <div class="space-y-20 md:space-y-28">
      {features.map((feature, idx) => (
        <div class={`grid md:grid-cols-2 gap-10 lg:gap-16 items-center ${idx % 2 === 1 ? 'md:[&>*:first-child]:order-2' : ''}`}>
          <div>
            <p class="inline-block px-3 py-1 rounded-full bg-brand-100 text-brand-800 text-xs font-bold tracking-wider uppercase mb-4">
              {feature.label}
            </p>
            <h3 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-slate-900 leading-tight">
              {feature.title}
            </h3>
            <p class="mt-5 text-lg text-slate-600 leading-relaxed">
              {feature.body}
            </p>
            <ul class="mt-6 space-y-3">
              {feature.bullets.map((b) => (
                <li class="flex items-start gap-3 text-slate-700">
                  <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <div class="relative mx-auto max-w-[300px] aspect-[886/1920] bg-slate-900 rounded-[2.5rem] p-1.5 shadow-xl ring-1 ring-slate-900/10">
              <div class="absolute inset-1.5 rounded-[2.2rem] overflow-hidden">
                <img src={feature.image} alt={feature.title} class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
