---
const appStoreUrl = 'https://apps.apple.com/app/id6762212456?utm_source=website&utm_medium=web&utm_campaign=launch';
---
<section id="cta" class="py-20 md:py-28">
  <div class="max-w-3xl mx-auto px-6">
    <div class="bg-gradient-to-br from-brand-700 to-brand-900 rounded-3xl p-10 md:p-14 text-center shadow-2xl shadow-brand-900/20">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white">
        Ready to track every reimbursable mile?
      </h2>
      <p class="mt-5 text-lg text-brand-100 max-w-xl mx-auto">
        EDU Mileage+ is now on the App Store. Free for 30 trips or 35 days — no credit card, no commitment.
      </p>

      <a
        href={appStoreUrl}
        data-ga-label="cta_download"
        rel="noopener"
        class="mt-8 inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900 text-brand-900 font-semibold px-7 py-3.5 rounded-full transition shadow-lg"
      >
        Download on the App Store
        <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>

      <p class="mt-6 text-sm text-brand-200">
        Built for K-12 educators · Privacy-respecting · No analytics, no ads
      </p>
    </div>
  </div>
</section>
