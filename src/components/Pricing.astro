---
---
<section id="pricing" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-14">
      <p class="text-sm font-semibold tracking-widest uppercase text-brand-700 mb-3">
        Pricing
      </p>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-slate-900">
        Simple, fair, and worth the first reimbursement check it captures.
      </h2>
      <p class="mt-5 text-lg text-slate-600">
        Try free for 30 trips or 35 days, whichever comes first. No commitment, no upfront card required.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <!-- Monthly -->
      <div class="bg-white rounded-3xl p-8 ring-1 ring-slate-200">
        <h3 class="font-display font-bold text-2xl text-slate-900">Monthly</h3>
        <p class="mt-2 text-sm text-slate-600">Pay as you go.</p>
        <div class="mt-6 flex items-baseline gap-1">
          <span class="text-5xl font-display font-bold tracking-tight text-slate-900">$5.99</span>
          <span class="text-slate-600 font-medium">/ month</span>
        </div>
        <a href="#cta" class="mt-7 block text-center bg-slate-900 hover:bg-slate-800 text-white font-semibold py-3 rounded-full transition">
          Get notified at launch
        </a>
        <ul class="mt-7 space-y-3 text-sm text-slate-700">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            One district included
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            Unlimited trips, automatic detection
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            PDF, CSV, and IRS Annual Reports
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            iCloud sync across your devices
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-slate-400 mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span class="text-slate-600">Cancel anytime</span>
          </li>
        </ul>
      </div>

      <!-- Annual (featured) -->
      <div class="bg-gradient-to-br from-brand-700 to-brand-900 rounded-3xl p-8 text-white ring-1 ring-brand-900/30 shadow-xl shadow-brand-900/20 relative">
        <div class="absolute -top-3 right-6 bg-white text-brand-900 text-xs font-bold tracking-wider uppercase px-3 py-1 rounded-full">
          Save 33%
        </div>
        <h3 class="font-display font-bold text-2xl">Annual</h3>
        <p class="mt-2 text-sm text-brand-100">Best value for full-year drivers.</p>
        <div class="mt-6 flex items-baseline gap-1">
          <span class="text-5xl font-display font-bold tracking-tight">$47.99</span>
          <span class="text-brand-100 font-medium">/ year</span>
        </div>
        <p class="mt-1 text-sm text-brand-100">Works out to $4.00/month.</p>
        <a href="#cta" class="mt-6 block text-center bg-white hover:bg-slate-50 text-brand-900 font-semibold py-3 rounded-full transition">
          Get notified at launch
        </a>
        <ul class="mt-7 space-y-3 text-sm text-brand-50">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-white mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            Everything in Monthly
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-white mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            Two months free vs. monthly billing
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-white mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            One charge, no monthly statement clutter
          </li>
        </ul>
      </div>
    </div>

    <!-- Add-on note -->
    <div class="max-w-4xl mx-auto mt-8 text-center text-sm text-slate-600">
      Work across two school districts? Add a second district for <strong class="text-slate-900">$1.99 / month</strong>. Manage the add-on inside the app.
    </div>
  </div>
</section>
