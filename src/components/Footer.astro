---
const year = new Date().getFullYear();
---
<footer class="bg-slate-900 text-slate-400 py-14">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-10 mb-10">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/icon.png" alt="" class="w-10 h-10 rounded-xl" />
          <span class="font-display font-semibold text-white text-lg">EDU Mileage+</span>
        </div>
        <p class="text-sm leading-relaxed">
          Mileage tracking built for K-12 educators and staff. Made by EDU Plus Apps.
        </p>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white text-sm tracking-wide uppercase mb-4">App</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="#features" class="hover:text-white transition">Features</a></li>
          <li><a href="#how-it-works" class="hover:text-white transition">How it works</a></li>
          <li><a href="#pricing" class="hover:text-white transition">Pricing</a></li>
          <li><a href="#faq" class="hover:text-white transition">FAQ</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white text-sm tracking-wide uppercase mb-4">Company</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="https://eduplusapps.com/support/" rel="noopener" class="hover:text-white transition">Support</a></li>
          <li><a href="https://eduplusapps.com/privacy/" rel="noopener" class="hover:text-white transition">Privacy Policy</a></li>
          <li><a href="https://eduplusapps.com/disclosure/" rel="noopener" class="hover:text-white transition">Disclosure</a></li>
          <li><a href="https://eduplusapps.com/" rel="noopener" class="hover:text-white transition">EDU Plus Apps</a></li>
          <li><a href="mailto:support@eduplusapps.com" class="hover:text-white transition">support@eduplusapps.com</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs">
      <p>© {year} EDU Plus Apps. All rights reserved.</p>
      <p>Designed and built for educators and school staff who drive.</p>
    </div>
  </div>
</footer>
