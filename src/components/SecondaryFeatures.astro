---
const features = [
  {
    icon: '☁️',
    title: 'iCloud sync',
    body: 'Your data backs up automatically and restores on a new device. Private CloudKit container — no third-party servers.',
  },
  {
    icon: '🗺️',
    title: 'Route maps on every trip',
    body: 'See the actual road you drove on a map in Trip Detail. GPS miles shown alongside Apple Maps reference distance.',
  },
  {
    icon: '✍️',
    title: 'Manual trip entry',
    body: 'Missed a drive? Log it after the fact with site picker, MKDirections auto-distance, and full purpose/notes fields.',
  },
  {
    icon: '📅',
    title: 'Schedule-aware tracking',
    body: 'Standard and alternate work schedules per district. Tracking only runs during your hours; out-of-schedule trips are offered for review.',
  },
  {
    icon: '📊',
    title: 'IRS Annual Report',
    body: 'Year-end cross-district summary with GPS, approved, and unreimbursed miles — useful for unreimbursed business expense tax filings.',
  },
  {
    icon: '🏠',
    title: 'Home Screen widget',
    body: 'Today\'s trip count and miles at a glance. Updates after every trip, rolls over at midnight.',
  },
  {
    icon: '🔒',
    title: 'Privacy-first',
    body: 'No analytics, no tracking, no ad networks. Your location data never leaves your device or your iCloud account.',
  },
  {
    icon: '🤝',
    title: 'Site sharing',
    body: 'Export your district\'s sites as a JSON file. Coworkers import to set up their app in minutes instead of hours.',
  },
];
---
<section class="py-20 md:py-28 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-14">
      <p class="text-sm font-semibold tracking-widest uppercase text-brand-700 mb-3">
        Plus everything else
      </p>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-slate-900">
        The details that turn a tracker into a tool you trust.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      {features.map((f) => (
        <div class="bg-white rounded-2xl p-6 ring-1 ring-slate-200/80 hover:ring-brand-300 hover:shadow-lg transition">
          <div class="text-3xl mb-3" aria-hidden="true">{f.icon}</div>
          <h3 class="font-display font-bold text-slate-900 mb-2">{f.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
