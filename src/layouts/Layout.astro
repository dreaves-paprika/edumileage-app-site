---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'EDU Mileage+ — Mileage tracking built for K-12 educators and staff',
  description = 'Automatically log every reimbursable mile between school sites. Built for the way district reimbursement actually works — IRS rates, multi-district support, approved distances, and audit-ready reports.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#177566" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content="EDU Mileage+" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Cloudflare Web Analytics is enabled via the Cloudflare dashboard for this Worker;
         no script tag is required here. -->

    <!-- JSON-LD: SoftwareApplication + Organization -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "EDU Mileage+",
      "operatingSystem": "iOS 26",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Mileage Tracking",
      "description": description,
      "url": "https://edumileage.app",
      "image": new URL('/icon.png', Astro.site).toString(),
      "offers": [
        {
          "@type": "Offer",
          "name": "Monthly subscription",
          "price": "5.99",
          "priceCurrency": "USD",
          "category": "Subscription"
        },
        {
          "@type": "Offer",
          "name": "Annual subscription",
          "price": "47.99",
          "priceCurrency": "USD",
          "category": "Subscription"
        }
      ],
      "publisher": {
        "@type": "Organization",
        "name": "EDU Plus Apps",
        "url": "https://eduplusapps.com",
        "logo": new URL('/icon.png', Astro.site).toString(),
        "email": "support@eduplusapps.com"
      }
    })} />
  </head>
  <body class="bg-white text-slate-900 font-sans selection:bg-brand-200 selection:text-brand-900">
    <slot />
  </body>
</html>
