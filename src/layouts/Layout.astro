---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'EDU Mileage+ — Mileage tracking built for K-12 educators and staff',
  description = 'iPhone mileage tracker for K-12 educators and staff. Free for 30 trips — automatic GPS detection, IRS rates, multi-district support, approved distances, and audit-ready reports.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const appStoreUrl = 'https://apps.apple.com/app/id6762212456';

const screenshotFiles = [
  '01_Dashboard.webp',
  '02_Trips.webp',
  '03_TripDetail.webp',
  '04_Reports.webp',
  '05_ReportDetail.webp',
];
const screenshots = screenshotFiles.map((f) => new URL(`/screenshots/${f}`, Astro.site).toString());
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#177566" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content="EDU Mileage+" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Cloudflare Web Analytics is enabled via the Cloudflare dashboard for this Worker;
         no script tag is required here. -->

    <!-- JSON-LD: SoftwareApplication + Organization -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "EDU Mileage+",
      "alternateName": "EDU Mileage Plus",
      "operatingSystem": "iOS 26",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Mileage Tracking",
      "description": description,
      "url": "https://edumileage.app",
      "image": new URL('/icon.png', Astro.site).toString(),
      "screenshot": screenshots,
      "softwareVersion": "1.0",
      "datePublished": "2026-04-29",
      "downloadUrl": appStoreUrl,
      "installUrl": appStoreUrl,
      "keywords": "mileage tracker, school district, K-12, educator, teacher, paraprofessional, paraeducator, itinerant teacher, special education, district office, IRS standard mileage rate, GPS, automatic, reimbursement, iPhone, iOS",
      "audience": {
        "@type": "EducationalAudience",
        "educationalRole": "K-12 school district employee"
      },
      "offers": [
        {
          "@type": "Offer",
          "name": "Monthly subscription",
          "price": "5.99",
          "priceCurrency": "USD",
          "category": "Subscription"
        },
        {
          "@type": "Offer",
          "name": "Annual subscription",
          "price": "47.99",
          "priceCurrency": "USD",
          "category": "Subscription"
        }
      ],
      "publisher": {
        "@type": "Organization",
        "name": "EDU Plus Apps",
        "url": "https://eduplusapps.com",
        "logo": new URL('/icon.png', Astro.site).toString(),
        "email": "support@eduplusapps.com"
      }
    })} />

    <!-- JSON-LD: VideoObject for product demo -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "name": "EDU Mileage+ product demo",
      "description": "A 30-second walkthrough of EDU Mileage+ — automatic trip detection, multi-district support, and audit-ready reimbursement reports for K-12 educators and staff.",
      "thumbnailUrl": new URL('/screenshots/01_Dashboard.webp', Astro.site).toString(),
      "uploadDate": "2026-04-27",
      "contentUrl": new URL('/video/Demo-final.mp4', Astro.site).toString(),
      "embedUrl": "https://edumileage.app/#top",
      "duration": "PT30S",
      "publisher": {
        "@type": "Organization",
        "name": "EDU Plus Apps",
        "url": "https://eduplusapps.com",
        "logo": new URL('/icon.png', Astro.site).toString()
      }
    })} />
  </head>
  <body class="bg-white text-slate-900 font-sans selection:bg-brand-200 selection:text-brand-900">
    <slot />
  </body>
</html>
